# Take a look at the mako manpage with the command:
#   man 5 mako
# To view all configuration options.

font=DejaVuSansMono Nerd Font Mono 12
format=<b>%a ⏵</b> %s\n%b
sort=-time
layer=overlay
anchor=top-right
width=300
height=110
margin=5
padding=0,5,10
border-size=1
border-radius=2
icons=1
max-icon-size=64
default-timeout=5000
ignore-timeout=1

[urgency=low]
border-color=#5C3723
background-color=#5C3723
text-color=#EDDDAA

[urgency=normal]
border-color=#5C3723
background-color=#5C3723
text-color=#EDDDAA

[urgency=high]
border-color=#5C3723
background-color=#D63A3E
text-color=#EDDDAA
default-timeout=0
